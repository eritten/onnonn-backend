{
  "name": "onnonn-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Onnonn Electron desktop application",
  "main": ".vite/build/main.js",
  "author": "Onnonn",
  "license": "MIT",
  "scripts": {
    "dev": "electron-forge start",
    "build": "vite build --config vite.main.config.js && vite build --config vite.preload.config.js && vite build --config vite.renderer.main.config.js",
    "package": "electron-forge package",
    "package:win": "npm run build && electron-builder --win",
    "make": "electron-forge make",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.niveel.onnonn",
    "productName": "Onnonn",
    "directories": {
      "output": "dist"
    },
    "files": [
      ".vite/**/*",
      "node_modules/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "createDesktopShortcut": true
    }
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true,
        "icon": "public/icon"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {}
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {}
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {}
        }
      ],
      "plugins": [
        {
          "name": "@electron-forge/plugin-vite",
          "config": {
            "build": [
              {
                "entry": "src/main/main.js",
                "config": "vite.main.config.js",
                "target": "main"
              },
              {
                "entry": "src/preload/preload.js",
                "config": "vite.preload.config.js",
                "target": "preload"
              }
            ],
            "renderer": [
              {
                "name": "main_window",
                "config": "vite.renderer.main.config.js"
              }
            ]
          }
        }
      ]
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@livekit/components-react": "^2.8.8",
    "axios": "^1.9.0",
    "date-fns": "^4.1.0",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.3.9",
    "livekit-client": "^2.15.7",
    "lucide-react": "^0.511.0",
    "machine-id": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.56.4",
    "react-hot-toast": "^2.5.2",
    "react-router-dom": "^6.30.0",
    "zod": "^3.24.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.7.0",
    "@electron-forge/maker-deb": "^7.7.0",
    "@electron-forge/maker-rpm": "^7.7.0",
    "@electron-forge/maker-squirrel": "^7.7.0",
    "@electron-forge/maker-zip": "^7.7.0",
    "@electron-forge/plugin-vite": "^7.7.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "electron": "^35.7.5",
    "electron-builder": "^24.13.3",
    "eslint": "^9.25.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.3",
    "recharts": "^2.15.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.2"
  }
}
